[sub_resource type="Shader" id="Shader_lightning"]
code = "shader_type canvas_item;
render_mode blend_add;

uniform float intensity : hint_range(0.0, 2.0) = 1.0;
uniform vec4 bolt_color : source_color = vec4(1.0, 0.92, 0.2, 1.0);
uniform float speed : hint_range(0.5, 10.0) = 5.0;

float hash(vec2 p) {
	return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453);
}

float noise(vec2 p) {
	vec2 i = floor(p);
	vec2 f = fract(p);
	vec2 u = f * f * (3.0 - 2.0 * f);
	return mix(
		mix(hash(i), hash(i + vec2(1.0, 0.0)), u.x),
		mix(hash(i + vec2(0.0, 1.0)), hash(i + vec2(1.0, 1.0)), u.x),
		u.y
	);
}

void fragment() {
	vec2 uv = UV;
	float t = TIME * speed;

	// Distance from nearest edge
	float dx = min(uv.x, 1.0 - uv.x);
	float dy = min(uv.y, 1.0 - uv.y);
	float edge = min(dx, dy);

	// Border glow falloff - strong at edges, fades inward
	float glow = exp(-edge * 16.0);

	// Two octaves of noise create forking bolt patterns
	float n1 = noise(uv * 10.0 + vec2(t, -t * 0.7));
	float n2 = noise(uv * 22.0 + vec2(-t * 1.3, t * 0.5));
	float bolt = pow(n1 * n2, 1.5) * 6.0;

	// Irregular on/off flicker (simulates arc discharge)
	float flicker = 0.55 + 0.45 * step(0.35, fract(sin(t * 5.7) * 43.0));

	// Bright flash burst every ~1.5s
	float flash = pow(max(0.0, sin(t * 2.1)), 30.0) * 0.5;

	float a = glow * (bolt * flicker + flash) * intensity;

	// Hot white core fading to yellow at weaker arcs
	vec3 col = mix(bolt_color.rgb, vec3(1.0), clamp(bolt * 0.3, 0.0, 1.0));

	COLOR = vec4(col, clamp(a, 0.0, 0.85));
}
"

